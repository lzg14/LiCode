{
  "// 说明": "licode 配置文件，放在项目根目录或 ~/.licode/config.json",
  "// 环境变量": "可设置 LICODE_MODEL / LICODE_PROVIDER / LICODE_API_KEY 覆盖以下值",
  "llm": {
    "provider": "deepseek",
    "// provider 可选": "anthropic | openai | deepseek | local",
    "model": "deepseek-chat",
    "// model 常用值": "deepseek: deepseek-chat, deepseek-coder | anthropic: claude-sonnet-4-20250514 | openai: gpt-4o",
    "apiKeyEnv": "ANTHROPIC_API_KEY",
    "// apiKeyEnv": "从环境变量读取 API Key 的变量名",
    "apiKey": "",
    "// apiKey": "直接填写 API Key（优先级高于 apiKeyEnv）",
    "baseUrl": "https://api.deepseek.com"
  },
  "security": {
    "commandWhitelist": ["git", "npm", "pnpm"],
    "allowedPaths": ["./"],
    "deniedPaths": [".git", ".env", ".ssh", ".aws", ".kube"]
  },
  "memory": {
    "path": "~/.licode/licode-sessions.db",
    "retentionDays": 30
  },
  "subagent": {
    "maxConcurrent": 3,
    "maxDepth": 1,
    "timeoutMs": 900000,
    "blockedTools": ["delegate_task", "clarify", "memory_write", "send_message", "execute_code"]
  },
  "mcp": {
    "// mcpServers": "MCP 服务器配置",
    "mcpServers": {
      "// filesystem": "示例：文件系统 MCP 服务器",
      "filesystem": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "."]
      }
    }
  }
}
